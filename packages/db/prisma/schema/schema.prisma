generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id          String    @id @default(cuid())
  num         Int       @unique @default(autoincrement()) // used to generate random shortUrlId string
  userId      String
  originalUrl String
  shortUrlId  String?   @unique
  visitCount  Int       @default(0)
  visitors    Visitor[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Visitor {
  id        String @id @default(cuid())
  ipAddress String
  urlId     String
  url       Url    @relation(fields: [urlId], references: [id])
}
